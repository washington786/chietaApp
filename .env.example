# Environment variables for Chieta app
# Copy this to .env and fill in your actual values

# API Configuration
EXPO_PUBLIC_API_URL=https://your-api.com/api
EXPO_PUBLIC_API_VERSION=v1

# Feature Flags
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=false

# Observability
EXPO_PUBLIC_ANALYTICS_KEY=your_analytics_key
EXPO_PUBLIC_LOG_ENDPOINT=https://your-api.com/logs

# Build-specific
EXPO_PUBLIC_BUILD_ENV=preview
EXPO_PUBLIC_APP_VARIANT=preview

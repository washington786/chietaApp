{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "cache": {
        "key": "npm-{{ hashFiles('package-lock.json') }}"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "distribution": "store"
      }
    },
    "preview2": {
      "distribution": "internal",
      "channel": "preview2",
      "autoIncrement": true,
      "cache": {
        "key": "npm-{{ hashFiles('package-lock.json') }}"
      }
    },
    "production": {
      "channel": "production",
      "distribution": "store",
      "developmentClient": false,
      "autoIncrement": true,
      "cache": {
        "key": "npm-{{ hashFiles('package-lock.json') }}"
      },
      "env": {
        "APP_ENV": "production"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    },
    "development": {
      "cache": {
        "key": "npm-{{ hashFiles('package-lock.json') }}"
      },
      "ios": {
        "simulator": true
      },
      "channel": "development"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "applicationId": "com.danielkarabo.Chieta",
        "track": "internal",
        "releaseStatus": "completed"
      },
      "ios": {
        "ascAppId": "6761328087",
        "ascApiKeyPath": "./asc-api-key.p8"
      }
    },
    "preview": {
      "ios": {
        "ascAppId": "6761328087"
      }
    }
  }
}
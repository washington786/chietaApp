{
    "cli": {
        "version": ">= 5.0.0"
    },
    "build": {
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "distribution": "internal"
            }
        },
        "preview2": {
            "distribution": "internal"
        },
        "production": {
            "channel": "production",
            "distribution": "store",
            "developmentClient": false,
            "autoIncrement": "version",
            "env": {
                "APP_ENV": "production"
            },
            "android": {
                "buildType": "app-bundle"
            },
            "ios": {
                "simulator": false
            }
        },
        "development": {
            "ios": {
                "simulator": true
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "track": "internal",
                "releaseStatus": "completed"
            },
            "ios": {
                "appName": "Chieta",
                "ascAppIdentifier": "com.danielkarabo.Chieta"
            }
        }
    }
}
